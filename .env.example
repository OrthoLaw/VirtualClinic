# Claude API key — runs the persona agents. Get one: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Figma personal access token — reads public share links via REST API.
# Create: Figma > Settings > Security > Personal access tokens (file_content:read scope)
FIGMA_TOKEN=

# Model for analysis. Sonnet = ~5x cheaper than Opus, strong vision (default).
# Use claude-opus-4-8 only for a max-accuracy final pass.
ANALYSIS_MODEL=claude-sonnet-4-6

# Token-cost knobs — images dominate cost (tokens ≈ width*height/750 per image).
# Render scale 1 is ~4x cheaper than 2. Fewer frames = linearly cheaper.
FIGMA_RENDER_SCALE=1
FIGMA_MAX_FRAMES=4

# Headless-browser executable for the HTML capture path.
# Local dev: leave blank, set CHROMIUM_LOCAL=1 to use your installed Chrome (see lib/html-capture.ts).
# Vercel/serverless: a remote chromium-min pack URL is fetched at runtime.
CHROMIUM_REMOTE_PACK=https://github.com/Sparticuz/chromium/releases/download/v131.0.0/chromium-v131.0.0-pack.tar
CHROMIUM_LOCAL=
